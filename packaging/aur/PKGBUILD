# Maintainer: Eric Frost <9555559+eric-frost@users.noreply.github.com>
pkgname=stitchfs-bin
pkgver=0.4.0
pkgrel=1
pkgdesc="Edit several files as one; saving splits the changes back into the originals"
arch=('x86_64' 'aarch64')
url="https://github.com/eric-frost/stitchfs"
license=('MIT')
depends=('fuse3')
provides=('stitchfs')
conflicts=('stitchfs')
source_x86_64=("$pkgname-$pkgver-x86_64.tar.gz::https://github.com/eric-frost/stitchfs/releases/download/v$pkgver/stitchfs_${pkgver}_linux_amd64.tar.gz")
source_aarch64=("$pkgname-$pkgver-aarch64.tar.gz::https://github.com/eric-frost/stitchfs/releases/download/v$pkgver/stitchfs_${pkgver}_linux_arm64.tar.gz")
sha256sums_x86_64=('6dd5caf0e044bd049c5dac4c555e02628fd5db334ef8074757bd0629b0995089')
sha256sums_aarch64=('35d881a82497f6cc69e38f66bb2a618af5cd3da9d0d44a781464b7757c1463a7')

package() {
	install -Dm755 stitchfs "$pkgdir/usr/bin/stitchfs"
	install -Dm755 packaging/stitchpath "$pkgdir/usr/bin/stitchpath"
	install -Dm644 packaging/stitchfs.service "$pkgdir/usr/lib/systemd/system/stitchfs.service"
	install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
	install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
